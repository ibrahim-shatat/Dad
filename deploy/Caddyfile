# Native Caddy config for the VM deploy. Install to /etc/caddy/Caddyfile.
# Set SITE_ADDRESS to your domain for automatic HTTPS, e.g.:
#   sudo caddy environ  (to check)  — or put it in /etc/default/caddy:
#   SITE_ADDRESS=dad.example.com
# With a bare IP and no domain, Caddy serves plain HTTP on :80 (no auto-HTTPS).
{$SITE_ADDRESS::80} {
	encode gzip

	# API -> uvicorn backend
	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	# Static SPA with client-side routing fallback
	handle {
		root * /opt/dad/frontend/dist
		try_files {path} /index.html
		file_server
	}
}
