[Unit]
Description=Dad API (uvicorn)
After=network.target postgresql.service redis-server.service
Wants=postgresql.service redis-server.service

[Service]
Type=simple
User=dad
Group=dad
WorkingDirectory=/opt/dad/backend
EnvironmentFile=/opt/dad/backend/.env
ExecStart=/opt/dad/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
