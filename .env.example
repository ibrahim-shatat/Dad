# Copy to .env and fill in real values. Never commit .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-5

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption for stored OAuth tokens (fernet key, 32 url-safe base64 bytes) ---
TOKEN_ENCRYPTION_KEY=

# --- Database ---
POSTGRES_USER=dad
POSTGRES_PASSWORD=dad
POSTGRES_DB=dad
DATABASE_URL=postgresql+asyncpg://dad:dad@db:5432/dad

# --- Redis / arq ---
REDIS_URL=redis://redis:6379/0

# --- Storage ---
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads

# --- Email OAuth (Phase 4) ---
# Gmail: Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web application).
#   Enable the Gmail API, add redirect URI {API_BASE_URL}/api/v1/email/gmail/callback.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Outlook: Microsoft Entra admin center -> App registrations -> New registration.
#   API permissions: Mail.Read, Mail.Send, User.Read, offline_access.
#   Add redirect URI {API_BASE_URL}/api/v1/email/outlook/callback.
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- URLs used to build OAuth redirect URIs and post-connect redirects ---
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- CORS / frontend ---
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000/api/v1
