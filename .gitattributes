# Keep files that run on Linux (deploy scripts, systemd units, Caddyfile, shell entrypoints)
# as LF regardless of the committer's OS, so CRLF from Windows never breaks them.
*.sh        text eol=lf
*.service   text eol=lf
entrypoint.sh text eol=lf
deploy/Caddyfile text eol=lf
Caddyfile   text eol=lf

# Normalize common text types; let Git decide the rest.
*.py   text
*.toml text
*.yaml text
*.yml  text
*.md   text
